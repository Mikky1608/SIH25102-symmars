# ========================================
# RESEND EMAIL SERVICE CONFIGURATION
# ========================================
# Get your free API key at: https://resend.com/signup
# Free tier: 3,000 emails/month, 100 emails/day
# No credit card required!

# Your Resend API Key (required)
RESEND_API_KEY=re_your_api_key_here

# From Email (use Resend test email or your verified domain)
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=Student Success Center

# Admin Email (receives notifications about at-risk students)
ADMIN_EMAIL=admin@university.edu

# Optional: University Name
UNIVERSITY_NAME=University Academic Services
